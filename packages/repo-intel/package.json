{
  "name": "repo-intel",
  "version": "0.1.0",
  "description": "Scan your repository and generate AI agent context files — powered by a Rust core",
  "keywords": ["ai", "agent", "context", "repository", "scanner", "llm"],
  "homepage": "https://github.com/ekaone/repo-intel",
  "repository": {
    "type": "git",
    "url": "https://github.com/ekaone/repo-intel"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "repo-intel": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "handlebars": "^4.7.8"
  },
  "optionalDependencies": {
    "repo-intel-linux-x64": "workspace:*",
    "repo-intel-darwin-arm64": "workspace:*",
    "repo-intel-darwin-x64": "workspace:*",
    "repo-intel-win32-x64": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}