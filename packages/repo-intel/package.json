{
  "name": "@ekaone/repo-intel",
  "version": "0.1.7",
  "description": "Scan your repository and generate AI agent context files — powered by a Rust core",
  "keywords": [
    "ai",
    "agent",
    "context",
    "repository",
    "scanner",
    "llm"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "homepage": "https://github.com/ekaone/repo-intel",
  "repository": {
    "type": "git",
    "url": "https://github.com/ekaone/repo-intel"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "repo-intel": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.41",
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "openai": "^4.77.0"
  },
  "optionalDependencies": {
    "@ekaone/repo-intel-darwin-arm64": "workspace:*",
    "@ekaone/repo-intel-darwin-x64": "workspace:*",
    "@ekaone/repo-intel-linux-x64": "workspace:*",
    "@ekaone/repo-intel-win32-x64": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}